meta {
  name: Rate order
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/orders/{{orderId}}/ratings
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
}

body:json {
  {
    "dropId": "{{dropId}}",
    "score": 5,
    "comment": "Best ramen"
  }
}

docs {
  Allowed only once the order is COMPLETED (run Track first). Otherwise returns 409.
}
