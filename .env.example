# Copy to .env for local development.
# Infra runs via docker-compose: Postgres on host port 5450, RabbitMQ on 5673/15673.
NODE_ENV=development

# --- Service HTTP ports (each service is its own NestJS app) ---
GATEWAY_PORT=4000
ORDER_PORT=4001
KITCHEN_PORT=4002
PAYMENT_PORT=4003
DISPATCH_PORT=4004
RATINGS_PORT=4005
NOTIFICATIONS_PORT=4006

# --- gRPC (sync gateway → services: reads, place/cancel order, rate; protobuf) ---
# Only order/kitchen/ratings expose gRPC. payment/dispatch are RMQ-only saga participants.
ORDER_GRPC_URL=localhost:5001
KITCHEN_GRPC_URL=localhost:5002
RATINGS_GRPC_URL=localhost:5005

# --- Database-per-service (one Postgres container, one DB per service) ---
ORDER_DATABASE_URL=postgresql://hotdrop:dev@localhost:5450/order
KITCHEN_DATABASE_URL=postgresql://hotdrop:dev@localhost:5450/kitchen
PAYMENT_DATABASE_URL=postgresql://hotdrop:dev@localhost:5450/payment
DISPATCH_DATABASE_URL=postgresql://hotdrop:dev@localhost:5450/dispatch
RATINGS_DATABASE_URL=postgresql://hotdrop:dev@localhost:5450/ratings

# --- RabbitMQ (saga command/reply + domain events) ---
RABBITMQ_URL=amqp://hotdrop:dev@localhost:5673

# --- OpenTelemetry → Jaeger (OTLP/HTTP). Jaeger UI: http://localhost:16686 ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Order / saga ---
PORTION_RESERVATION_TTL_SECONDS=600
REFUND_WINDOW_MINUTES=0

# --- Emulated payment gateway (latency / failure rate / idempotency by orderId) ---
PAYMENT_FAILURE_RATE=0
PAYMENT_LATENCY_MS=0

# --- Emulated dispatch / gig couriers (decline rate triggers reassignment) ---
COURIER_DECLINE_RATE=0
COURIER_LATENCY_MS=0
